<Window
    x:Class="VideoCutEditor.ExportListWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:VideoCutEditor.Core.Models"
    Title="書き出しリスト">

    <Grid x:Name="ExportListRoot" Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="12,0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="開始地点" />
            <TextBlock Grid.Column="1" Style="{StaticResource BodyStrongTextBlockStyle}" Text="終了地点" />
            <TextBlock Grid.Column="2" Style="{StaticResource BodyStrongTextBlockStyle}" Text="タイトル" />
        </Grid>

        <ListView
            Grid.Row="1"
            AutomationProperties.AutomationId="ExportClipListView"
            IsEnabled="{x:Bind ViewModel.CanEditRegisteredClips, Mode=OneWay}"
            ItemsSource="{x:Bind ViewModel.RegisteredClips, Mode=OneWay}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:ExportClip">
                    <Grid MinHeight="40" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" Text="{x:Bind StartText}" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind EndText}" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Text="{x:Bind Title}"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="3"
                            AutomationProperties.AutomationId="RemoveClipButton"
                            AutomationProperties.Name="登録を削除"
                            HorizontalAlignment="Center"
                            Click="RemoveClipButton_Click"
                            ToolTipService.ToolTip="登録を削除">
                            <FontIcon FontSize="16" Glyph="&#xE74D;" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
