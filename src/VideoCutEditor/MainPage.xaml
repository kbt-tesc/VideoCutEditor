<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VideoCutEditor.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:VideoCutEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid
        x:Name="EditorRoot"
        AutomationProperties.AutomationId="EditorDropTarget"
        AllowDrop="True"
        Background="Transparent"
        DragOver="EditorRoot_DragOver"
        Drop="EditorRoot_Drop"
        IsTabStop="True"
        KeyDown="EditorRoot_KeyDown"
        Padding="24"
        RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                AutomationProperties.AutomationId="OpenVideoButton"
                Command="{x:Bind ViewModel.OpenVideoCommand}"
                ToolTipService.ToolTip="Open video">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE8E5;" />
                    <TextBlock Text="Open" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <TextBlock
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="{x:Bind ViewModel.SelectedFileName, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.SelectedSourcePath, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <TextBlock
                Grid.Column="2"
                AutomationProperties.AutomationId="StatusMessageText"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <MediaPlayerElement
                            x:Name="PreviewPlayer"
                            AreTransportControlsEnabled="False"
                            Source="{x:Bind ViewModel.PreviewSource, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Preview"
                            Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsPreviewPlaceholderVisible), Mode=OneWay}" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid Padding="16" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button
                                AutomationProperties.AutomationId="PlayPauseButton"
                                Click="PlayPauseButton_Click"
                                ToolTipService.ToolTip="Play or pause">
                                <FontIcon FontSize="16" Glyph="&#xE768;" />
                            </Button>

                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="MarkStartButton"
                                AutomationProperties.Name="Set start to current position"
                                Command="{x:Bind ViewModel.MarkStartCommand}"
                                ToolTipService.ToolTip="Set start to current position">
                                <TextBlock Text="[" />
                            </Button>

                            <Button
                                Grid.Column="2"
                                AutomationProperties.AutomationId="MarkEndButton"
                                AutomationProperties.Name="Set end to current position"
                                Command="{x:Bind ViewModel.MarkEndCommand}"
                                ToolTipService.ToolTip="Set end to current position">
                                <TextBlock Text="]" />
                            </Button>

                            <TextBlock
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.PositionText, Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="4"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.DurationText, Mode=OneWay}" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ScrollViewer
                                x:Name="TimelineScrollViewer"
                                AutomationProperties.AutomationId="TimelineScrollViewer"
                                Height="156"
                                HorizontalScrollBarVisibility="Auto"
                                HorizontalScrollMode="Enabled"
                                SizeChanged="TimelineScrollViewer_SizeChanged"
                                VerticalScrollBarVisibility="Disabled"
                                VerticalScrollMode="Disabled"
                                ZoomMode="Disabled">
                                <Canvas
                                    x:Name="TimelineCanvas"
                                    Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                    Height="148"
                                    Background="Transparent"
                                    PointerPressed="TimelineCanvas_PointerPressed">
                                    <Rectangle
                                        x:Name="TimelineBackground"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="148"
                                        Fill="{ThemeResource LayerFillColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="TimelineRulerBand"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="28"
                                        Fill="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" />
                                    <Canvas
                                        x:Name="TimelineTicksCanvas"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="28" />
                                    <Rectangle
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="1"
                                        Canvas.Top="28"
                                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                    <Image
                                        x:Name="WaveformImage"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="88"
                                        Canvas.Top="40"
                                        Opacity="0.95"
                                        Stretch="Fill" />
                                    <Rectangle
                                        x:Name="WaveformCenterLine"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="1"
                                        Canvas.Top="84"
                                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="SelectedRangeFill"
                                        Height="104"
                                        Canvas.Top="32"
                                        Fill="{ThemeResource SystemFillColorAttentionBackgroundBrush}" />
                                    <Rectangle
                                        x:Name="RangeStartMarker"
                                        Width="4"
                                        Height="120"
                                        Canvas.Top="28"
                                        Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="RangeEndMarker"
                                        Width="4"
                                        Height="120"
                                        Canvas.Top="28"
                                        Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="PlayheadMarker"
                                        Width="2"
                                        Height="140"
                                        Canvas.Top="4"
                                        Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Canvas>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="2" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="RangeStartTextBox"
                                Header="Start"
                                Text="{x:Bind ViewModel.RangeStartText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox
                                Grid.Column="1"
                                AutomationProperties.AutomationId="RangeEndTextBox"
                                Header="End"
                                Text="{x:Bind ViewModel.RangeEndText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                Text="Zoom" />
                            <Slider
                                x:Name="TimelineZoomSlider"
                                Grid.Column="1"
                                AutomationProperties.AutomationId="TimelineZoomSlider"
                                Maximum="8"
                                Minimum="1"
                                StepFrequency="1"
                                Value="1"
                                ValueChanged="TimelineZoomSlider_ValueChanged" />
                            <TextBlock
                                Grid.Column="2"
                                MinWidth="44"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.TimelineZoomText, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Text="Speed" />
                            <ComboBox
                                x:Name="PlaybackRateComboBox"
                                Grid.Column="4"
                                AutomationProperties.AutomationId="PlaybackRateComboBox"
                                SelectedIndex="3"
                                SelectionChanged="PlaybackRateComboBox_SelectionChanged">
                                <ComboBoxItem Content="0.25x" />
                                <ComboBoxItem Content="0.5x" />
                                <ComboBoxItem Content="0.75x" />
                                <ComboBoxItem Content="1x" />
                            </ComboBox>
                            <TextBlock
                                Grid.Column="5"
                                MinWidth="44"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.PlaybackRateText, Mode=OneWay}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer>
                    <StackPanel Margin="0,0,24,0" Spacing="16">
                        <TextBlock Text="Export" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <ComboBox
                            AutomationProperties.AutomationId="ExportModeComboBox"
                            Header="Mode"
                            HorizontalAlignment="Stretch"
                            SelectedIndex="{x:Bind ViewModel.SelectedExportModeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Fast copy" />
                            <ComboBoxItem Content="Re-encode" />
                        </ComboBox>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox
                                AutomationProperties.AutomationId="CodecFamilyComboBox"
                                Header="Codec"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.SelectedCodecFamilyIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="H.264" />
                                <ComboBoxItem Content="H.265" />
                                <ComboBoxItem Content="AV1" />
                            </ComboBox>

                            <ComboBox
                                Grid.Column="1"
                                AutomationProperties.AutomationId="EncoderKindComboBox"
                                Header="Encoder"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.SelectedEncoderKindIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Auto" />
                                <ComboBoxItem Content="NVEnc" />
                                <ComboBoxItem Content="Software" />
                            </ComboBox>
                        </Grid>

                        <TextBox
                            AutomationProperties.AutomationId="VideoBitrateTextBox"
                            Header="Video bitrate (kbps)"
                            InputScope="Number"
                            Text="{x:Bind ViewModel.VideoBitrateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox
                            AutomationProperties.AutomationId="PredictedOutputSizeTextBox"
                            Header="Predicted output size"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.PredictedOutputSizeText, Mode=OneWay}" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="FfmpegPathTextBox"
                                Header="ffmpeg"
                                Text="{x:Bind ViewModel.FfmpegPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="BrowseFfmpegPathButton"
                                AutomationProperties.Name="Choose ffmpeg executable"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.BrowseFfmpegPathCommand}"
                                ToolTipService.ToolTip="Choose ffmpeg executable">
                                <FontIcon FontSize="16" Glyph="&#xE8E5;" />
                            </Button>
                        </Grid>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="FfprobePathTextBox"
                                Header="ffprobe"
                                Text="{x:Bind ViewModel.FfprobePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="BrowseFfprobePathButton"
                                AutomationProperties.Name="Choose ffprobe executable"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.BrowseFfprobePathCommand}"
                                ToolTipService.ToolTip="Choose ffprobe executable">
                                <FontIcon FontSize="16" Glyph="&#xE8E5;" />
                            </Button>
                        </Grid>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="OutputDirectoryTextBox"
                                Header="Output folder"
                                Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="BrowseOutputDirectoryButton"
                                AutomationProperties.Name="Choose output folder"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.BrowseOutputDirectoryCommand}"
                                ToolTipService.ToolTip="Choose output folder">
                                <FontIcon FontSize="16" Glyph="&#xE8B7;" />
                            </Button>
                        </Grid>

                        <TextBox
                            AutomationProperties.AutomationId="PlannedOutputTextBox"
                            Header="Planned output"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.PlannedOutputPath, Mode=OneWay}" />

                        <StackPanel
                            Spacing="8"
                            Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsExporting), Mode=OneWay}">
                            <ProgressBar
                                AutomationProperties.AutomationId="ExportProgressBar"
                                IsIndeterminate="{x:Bind ViewModel.IsExportProgressIndeterminate, Mode=OneWay}"
                                Maximum="1"
                                Minimum="0"
                                Value="{x:Bind ViewModel.ExportProgressValue, Mode=OneWay}" />
                        </StackPanel>

                        <TextBox
                            AutomationProperties.AutomationId="ExportLogTextBox"
                            Header="Export log"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="120"
                            Text="{x:Bind ViewModel.ExportLogText, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBox
                            AutomationProperties.AutomationId="EncoderSummaryTextBox"
                            Header="Encoder capabilities"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="96"
                            Text="{x:Bind ViewModel.EncoderSummaryText, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBox
                            AutomationProperties.AutomationId="MediaInfoTextBox"
                            Header="Media info"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="120"
                            Text="{x:Bind ViewModel.MediaSummaryText, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        AutomationProperties.AutomationId="SaveSettingsButton"
                        AutomationProperties.Name="Save settings"
                        Width="48"
                        Command="{x:Bind ViewModel.SaveSettingsCommand}"
                        ToolTipService.ToolTip="Save settings">
                        <FontIcon FontSize="16" Glyph="&#xE74E;" />
                    </Button>

                    <Button
                        Grid.Column="1"
                        AutomationProperties.AutomationId="CancelExportButton"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CancelExportCommand}"
                        IsEnabled="{x:Bind ViewModel.IsExporting, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE711;" />
                            <TextBlock Text="Cancel" />
                        </StackPanel>
                    </Button>

                    <Button
                        Grid.Column="2"
                        AutomationProperties.AutomationId="ExportButton"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ExportCommand}"
                        IsEnabled="{x:Bind local:MainPage.IsNotBusy(ViewModel.IsExporting), Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE118;" />
                            <TextBlock Text="Export" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <InfoBar
            Grid.Row="2"
            IsOpen="True"
            IsClosable="False"
            Message="Fast copy preserves streams where practical, but cuts can align to nearby keyframes."
            Severity="Informational" />
    </Grid>
</Page>
