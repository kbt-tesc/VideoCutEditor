<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VideoCutEditor.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:formatting="using:Windows.Globalization.NumberFormatting"
    xmlns:local="using:VideoCutEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <formatting:DecimalFormatter
            x:Key="FadeDurationNumberFormatter"
            FractionDigits="2"
            IsGrouped="False" />
        <formatting:DecimalFormatter
            x:Key="TargetSizeNumberFormatter"
            FractionDigits="2"
            IsGrouped="False" />
        <formatting:DecimalFormatter
            x:Key="QualityNumberFormatter"
            FractionDigits="0"
            IsGrouped="False" />
    </Page.Resources>

    <Grid
        x:Name="EditorRoot"
        AutomationProperties.AutomationId="EditorDropTarget"
        AllowDrop="True"
        Background="Transparent"
        DragOver="EditorRoot_DragOver"
        Drop="EditorRoot_Drop"
        IsTabStop="True"
        Padding="24"
        RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                AutomationProperties.AutomationId="OpenVideoButton"
                Command="{x:Bind ViewModel.OpenVideoCommand}"
                ToolTipService.ToolTip="動画を開く">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="16" Glyph="&#xE8E5;" />
                    <TextBlock Text="開く" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <TextBlock
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="{x:Bind ViewModel.SelectedFileName, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.SelectedSourcePath, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <TextBlock
                Grid.Column="2"
                AutomationProperties.AutomationId="StatusMessageText"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid>
                        <MediaPlayerElement
                            x:Name="PreviewPlayer"
                            AreTransportControlsEnabled="False"
                            Source="{x:Bind ViewModel.PreviewSource, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="プレビュー"
                            Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsPreviewPlaceholderVisible), Mode=OneWay}" />
                    </Grid>
                </Border>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <Grid Padding="16" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button
                                AutomationProperties.AutomationId="PlayPauseButton"
                                Click="PlayPauseButton_Click"
                                ToolTipService.ToolTip="再生または一時停止">
                                <FontIcon FontSize="16" Glyph="&#xE768;" />
                            </Button>

                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="MarkStartButton"
                                AutomationProperties.Name="現在位置を開始地点にする"
                                Command="{x:Bind ViewModel.MarkStartCommand}"
                                ToolTipService.ToolTip="現在位置を開始地点にする">
                                <TextBlock Text="[" />
                            </Button>

                            <Button
                                Grid.Column="2"
                                AutomationProperties.AutomationId="MarkEndButton"
                                AutomationProperties.Name="現在位置を終了地点にする"
                                Command="{x:Bind ViewModel.MarkEndCommand}"
                                ToolTipService.ToolTip="現在位置を終了地点にする">
                                <TextBlock Text="]" />
                            </Button>

                            <TextBlock
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.PositionText, Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="4"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.DurationText, Mode=OneWay}" />
                        </Grid>

                        <Border
                            Grid.Row="1"
                            Background="{ThemeResource ControlFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ScrollViewer
                                x:Name="TimelineScrollViewer"
                                AutomationProperties.AutomationId="TimelineScrollViewer"
                                Height="156"
                                HorizontalScrollBarVisibility="Auto"
                                HorizontalScrollMode="Enabled"
                                SizeChanged="TimelineScrollViewer_SizeChanged"
                                VerticalScrollBarVisibility="Disabled"
                                VerticalScrollMode="Disabled"
                                ZoomMode="Disabled">
                                <Canvas
                                    x:Name="TimelineCanvas"
                                    Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                    Height="148"
                                    Background="Transparent"
                                    PointerCanceled="TimelineCanvas_PointerCanceled"
                                    PointerMoved="TimelineCanvas_PointerMoved"
                                    PointerPressed="TimelineCanvas_PointerPressed"
                                    PointerReleased="TimelineCanvas_PointerReleased">
                                    <Rectangle
                                        x:Name="TimelineBackground"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="148"
                                        Fill="{ThemeResource LayerFillColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="TimelineRulerBand"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="28"
                                        Fill="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" />
                                    <Canvas
                                        x:Name="TimelineTicksCanvas"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="28" />
                                    <Rectangle
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="1"
                                        Canvas.Top="28"
                                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                    <Image
                                        x:Name="WaveformImage"
                                        AutomationProperties.AutomationId="WaveformImage"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="88"
                                        Canvas.Top="40"
                                        Opacity="0.95"
                                        Stretch="Fill" />
                                    <Rectangle
                                        x:Name="WaveformCenterLine"
                                        Width="{x:Bind ViewModel.TimelineContentWidth, Mode=OneWay}"
                                        Height="1"
                                        Canvas.Top="84"
                                        Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="SelectedRangeFill"
                                        Height="104"
                                        Canvas.Top="32"
                                        Fill="{ThemeResource SystemFillColorAttentionBackgroundBrush}" />
                                    <Rectangle
                                        x:Name="RangeStartMarker"
                                        Width="1"
                                        Height="120"
                                        Canvas.Top="28"
                                        Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="RangeEndMarker"
                                        Width="1"
                                        Height="120"
                                        Canvas.Top="28"
                                        Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                    <Rectangle
                                        x:Name="PlayheadMarker"
                                        Width="2"
                                        Height="140"
                                        Canvas.Top="4"
                                        Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                </Canvas>
                            </ScrollViewer>
                        </Border>

                        <Grid Grid.Row="2" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="RangeStartTextBox"
                                Header="開始"
                                Text="{x:Bind ViewModel.RangeStartText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox
                                Grid.Column="1"
                                AutomationProperties.AutomationId="RangeEndTextBox"
                                Header="終了"
                                Text="{x:Bind ViewModel.RangeEndText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Grid.Row="3" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                VerticalAlignment="Center"
                                Text="ズーム" />
                            <Slider
                                x:Name="TimelineZoomSlider"
                                Grid.Column="1"
                                AutomationProperties.AutomationId="TimelineZoomSlider"
                                Maximum="8"
                                Minimum="1"
                                StepFrequency="1"
                                Value="1"
                                ValueChanged="TimelineZoomSlider_ValueChanged" />
                            <TextBlock
                                Grid.Column="2"
                                MinWidth="44"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.TimelineZoomText, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="3"
                                VerticalAlignment="Center"
                                Text="速度" />
                            <ComboBox
                                x:Name="PlaybackRateComboBox"
                                Grid.Column="4"
                                AutomationProperties.AutomationId="PlaybackRateComboBox"
                                SelectedIndex="3"
                                SelectionChanged="PlaybackRateComboBox_SelectionChanged">
                                <ComboBoxItem Content="0.25x" />
                                <ComboBoxItem Content="0.5x" />
                                <ComboBoxItem Content="0.75x" />
                                <ComboBoxItem Content="1x" />
                            </ComboBox>
                            <TextBlock
                                Grid.Column="5"
                                MinWidth="44"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.PlaybackRateText, Mode=OneWay}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer>
                    <StackPanel Margin="0,0,24,0" Spacing="16">
                        <TextBlock Text="書き出し" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <RadioButtons
                            AutomationProperties.AutomationId="ExportModeRadioButtons"
                            Header="モード"
                            MaxColumns="2"
                            SelectedIndex="{x:Bind ViewModel.SelectedExportModeIndex, Mode=TwoWay}">
                            <x:String>Fast copy</x:String>
                            <x:String>Re-encode</x:String>
                        </RadioButtons>

                        <CheckBox
                            AutomationProperties.AutomationId="NormalizeAudioCheckBox"
                            Content="音量を正規化 (-14 LUFS)"
                            IsChecked="{x:Bind ViewModel.NormalizeAudioEnabled, Mode=TwoWay}" />

                        <StackPanel
                            Spacing="16"
                            Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsReencodeSettingsVisible), Mode=OneWay}">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox
                                    AutomationProperties.AutomationId="CodecFamilyComboBox"
                                    Header="コーデック"
                                    HorizontalAlignment="Stretch"
                                    SelectedIndex="{x:Bind ViewModel.SelectedCodecFamilyIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="H.264" />
                                    <ComboBoxItem Content="H.265" />
                                    <ComboBoxItem Content="AV1" />
                                </ComboBox>

                                <ComboBox
                                    Grid.Column="1"
                                    AutomationProperties.AutomationId="EncoderKindComboBox"
                                    Header="エンコーダー"
                                    HorizontalAlignment="Stretch"
                                    SelectedIndex="{x:Bind ViewModel.SelectedEncoderKindIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="Auto" />
                                    <ComboBoxItem Content="NVEnc" />
                                    <ComboBoxItem Content="Software" />
                                </ComboBox>
                            </Grid>

                            <ComboBox
                                AutomationProperties.AutomationId="BitrateModeComboBox"
                                Header="レート制御"
                                HorizontalAlignment="Stretch"
                                SelectedIndex="{x:Bind ViewModel.SelectedBitrateModeIndex, Mode=TwoWay}">
                                <ComboBoxItem Content="Video bitrate" />
                                <ComboBoxItem Content="Target size" />
                                <ComboBoxItem Content="Quality" />
                            </ComboBox>

                            <TextBox
                                AutomationProperties.AutomationId="VideoBitrateTextBox"
                                Header="映像ビットレート (kbps)"
                                IsEnabled="{x:Bind ViewModel.IsBitrateMode, Mode=OneWay}"
                                InputScope="Number"
                                Text="{x:Bind ViewModel.VideoBitrateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <NumberBox
                                AutomationProperties.AutomationId="TargetSizeNumberBox"
                                Header="目標サイズ (MB)"
                                IsEnabled="{x:Bind ViewModel.IsTargetSizeMode, Mode=OneWay}"
                                LargeChange="10"
                                Maximum="1048576"
                                Minimum="1"
                                NumberFormatter="{StaticResource TargetSizeNumberFormatter}"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.TargetSizeMegabytes, Mode=TwoWay}" />

                            <NumberBox
                                AutomationProperties.AutomationId="QualityNumberBox"
                                Header="品質 (小さいほど高品質)"
                                IsEnabled="{x:Bind ViewModel.IsQualityMode, Mode=OneWay}"
                                LargeChange="5"
                                Maximum="51"
                                Minimum="0"
                                NumberFormatter="{StaticResource QualityNumberFormatter}"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.QualityValue, Mode=TwoWay}" />

                            <TextBox
                                AutomationProperties.AutomationId="PredictedOutputSizeTextBox"
                                Header="推定出力サイズ"
                                IsReadOnly="True"
                                Text="{x:Bind ViewModel.PredictedOutputSizeText, Mode=OneWay}" />

                            <StackPanel Spacing="8">
                                <TextBlock Text="フェード" Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <Grid ColumnSpacing="8" RowSpacing="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox
                                        AutomationProperties.AutomationId="VideoFadeInCheckBox"
                                        Content="映像イン"
                                        IsChecked="{x:Bind ViewModel.VideoFadeInEnabled, Mode=TwoWay}" />
                                    <CheckBox
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="VideoFadeOutCheckBox"
                                        Content="映像アウト"
                                        IsChecked="{x:Bind ViewModel.VideoFadeOutEnabled, Mode=TwoWay}" />
                                    <CheckBox
                                        Grid.Row="1"
                                        AutomationProperties.AutomationId="AudioFadeInCheckBox"
                                        Content="音声イン"
                                        IsChecked="{x:Bind ViewModel.AudioFadeInEnabled, Mode=TwoWay}" />
                                    <CheckBox
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        AutomationProperties.AutomationId="AudioFadeOutCheckBox"
                                        Content="音声アウト"
                                        IsChecked="{x:Bind ViewModel.AudioFadeOutEnabled, Mode=TwoWay}" />
                                </Grid>

                                <NumberBox
                                    AutomationProperties.AutomationId="FadeDurationNumberBox"
                                    Header="フェード時間 (秒)"
                                    LargeChange="0.25"
                                    Maximum="30"
                                    Minimum="0.25"
                                    NumberFormatter="{StaticResource FadeDurationNumberFormatter}"
                                    SmallChange="0.25"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.FadeDurationSeconds, Mode=TwoWay}" />
                            </StackPanel>

                            <TextBox
                                AutomationProperties.AutomationId="AdditionalFfmpegArgumentsTextBox"
                                Header="追加 ffmpeg 引数"
                                Text="{x:Bind ViewModel.AdditionalFfmpegArgumentsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="FfmpegPathTextBox"
                                Header="ffmpeg"
                                Text="{x:Bind ViewModel.FfmpegPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="BrowseFfmpegPathButton"
                                AutomationProperties.Name="ffmpeg.exe を選択"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.BrowseFfmpegPathCommand}"
                                ToolTipService.ToolTip="ffmpeg.exe を選択">
                                <FontIcon FontSize="16" Glyph="&#xE8E5;" />
                            </Button>
                        </Grid>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="FfprobePathTextBox"
                                Header="ffprobe"
                                Text="{x:Bind ViewModel.FfprobePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="BrowseFfprobePathButton"
                                AutomationProperties.Name="ffprobe.exe を選択"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.BrowseFfprobePathCommand}"
                                ToolTipService.ToolTip="ffprobe.exe を選択">
                                <FontIcon FontSize="16" Glyph="&#xE8E5;" />
                            </Button>
                        </Grid>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox
                                AutomationProperties.AutomationId="OutputDirectoryTextBox"
                                Header="出力フォルダー"
                                Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="BrowseOutputDirectoryButton"
                                AutomationProperties.Name="出力フォルダーを選択"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.BrowseOutputDirectoryCommand}"
                                ToolTipService.ToolTip="出力フォルダーを選択">
                                <FontIcon FontSize="16" Glyph="&#xE8B7;" />
                            </Button>
                            <Button
                                Grid.Column="2"
                                AutomationProperties.AutomationId="OpenOutputDirectoryButton"
                                AutomationProperties.Name="出力フォルダーを開く"
                                VerticalAlignment="Bottom"
                                Command="{x:Bind ViewModel.OpenOutputDirectoryCommand}"
                                ToolTipService.ToolTip="出力フォルダーを開く">
                                <FontIcon FontSize="16" Glyph="&#xE838;" />
                            </Button>
                        </Grid>

                        <TextBox
                            AutomationProperties.AutomationId="PlannedOutputTextBox"
                            Header="出力予定"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.PlannedOutputPath, Mode=OneWay}" />

                        <StackPanel
                            Spacing="8"
                            Visibility="{x:Bind local:MainPage.BoolToVisibility(ViewModel.IsExporting), Mode=OneWay}">
                            <ProgressBar
                                AutomationProperties.AutomationId="ExportProgressBar"
                                IsIndeterminate="{x:Bind ViewModel.IsExportProgressIndeterminate, Mode=OneWay}"
                                Maximum="1"
                                Minimum="0"
                                Value="{x:Bind ViewModel.ExportProgressValue, Mode=OneWay}" />
                        </StackPanel>

                        <TextBox
                            AutomationProperties.AutomationId="ExportLogTextBox"
                            Header="書き出しログ"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="120"
                            Text="{x:Bind ViewModel.ExportLogText, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBox
                            AutomationProperties.AutomationId="EncoderSummaryTextBox"
                            Header="エンコーダー情報"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="96"
                            Text="{x:Bind ViewModel.EncoderSummaryText, Mode=OneWay}"
                            TextWrapping="Wrap" />

                        <TextBox
                            AutomationProperties.AutomationId="MediaInfoTextBox"
                            Header="メディア情報"
                            AcceptsReturn="True"
                            IsReadOnly="True"
                            MinHeight="120"
                            Text="{x:Bind ViewModel.MediaSummaryText, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        AutomationProperties.AutomationId="SaveSettingsButton"
                        AutomationProperties.Name="設定を保存"
                        Width="48"
                        Command="{x:Bind ViewModel.SaveSettingsCommand}"
                        ToolTipService.ToolTip="設定を保存">
                        <FontIcon FontSize="16" Glyph="&#xE74E;" />
                    </Button>

                    <Button
                        Grid.Column="1"
                        AutomationProperties.AutomationId="CancelExportButton"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CancelExportCommand}"
                        IsEnabled="{x:Bind ViewModel.IsExporting, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE711;" />
                            <TextBlock Text="キャンセル" />
                        </StackPanel>
                    </Button>

                    <Button
                        Grid.Column="2"
                        AutomationProperties.AutomationId="ExportButton"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ExportCommand}"
                        IsEnabled="{x:Bind local:MainPage.IsNotBusy(ViewModel.IsExporting), Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="16" Glyph="&#xE118;" />
                            <TextBlock Text="書き出し" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <InfoBar
            Grid.Row="2"
            IsOpen="True"
            IsClosable="False"
            Message="{x:Bind ViewModel.ExportNoticeText, Mode=OneWay}"
            Severity="Informational" />
    </Grid>
</Page>
